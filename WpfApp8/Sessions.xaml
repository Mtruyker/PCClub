<UserControl x:Class="PCClubAdmin.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="20">
        <TextBlock Text="Управление сессиями" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Панель управления -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить сессию" Command="{Binding ShowAddDialogCommand}" Width="120" Height="30" Margin="0,0,10,0"/>
            <Button Content="Обновить список" Command="{Binding RefreshSessionsCommand}" Width="120" Height="30"/>
        </StackPanel>

        <!-- Диалоговое окно добавления сессии -->
        <Border Visibility="{Binding IsAddDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Добавление новой сессии" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Клиент:" FontWeight="SemiBold"/>
                    <ComboBox Height="25" Margin="0,5,0,0"
                              ItemsSource="{Binding AvailableClients}"
                              SelectedItem="{Binding SelectedClientName}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Компьютер:" FontWeight="SemiBold"/>
                    <ComboBox Height="25" Margin="0,5,0,0"
                              ItemsSource="{Binding AvailableComputers}"
                              SelectedItem="{Binding SelectedComputerName}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Тариф:" FontWeight="SemiBold"/>
                    <ComboBox Height="25" Margin="0,5,0,0"
                              ItemsSource="{Binding AvailableTariffs}"
                              SelectedItem="{Binding SelectedTariff}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Command="{Binding SaveSessionCommand}" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Отмена" Command="{Binding CancelAddSessionCommand}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица сессий -->
        <DataGrid AutoGenerateColumns="False" Height="400" CanUserAddRows="False" ItemsSource="{Binding Sessions}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="150"/>
                <DataGridTextColumn Header="Компьютер" Binding="{Binding ComputerName}" Width="100"/>
                <DataGridTextColumn Header="Тариф" Binding="{Binding TariffName}" Width="100"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding FormattedStartTime}" Width="130"/>
                <DataGridTextColumn Header="Окончание" Binding="{Binding FormattedEndTime}" Width="130"/>
                <DataGridTextColumn Header="Продолжительность" Binding="{Binding Duration}" Width="120"/>
                <DataGridTextColumn Header="Стоимость" Binding="{Binding FormattedCost}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Завершить"
                                        Command="{Binding DataContext.EndSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,5,0"/>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>