<UserControl x:Class="PCClubAdmin.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Статистика клуба" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <GroupBox Grid.Row="1" Header="Фильтры статистики" Margin="0,0,0,16">
            <WrapPanel Margin="8" VerticalAlignment="Center">
                <StackPanel Width="160" Margin="0,0,16,8">
                    <TextBlock Text="Период:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Height="25"
                              ItemsSource="{Binding Periods}"
                              SelectedItem="{Binding SelectedPeriod}"/>
                </StackPanel>

                <StackPanel Width="170" Margin="0,0,16,8">
                    <TextBlock Text="Компьютер:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Height="25"
                              ItemsSource="{Binding Computers}"
                              SelectedItem="{Binding SelectedComputer}"/>
                </StackPanel>

                <Button Content="Применить фильтры"
                        Command="{Binding ApplyFiltersCommand}"
                        Width="130"
                        Height="30"
                        Margin="0,18,0,8"/>
            </WrapPanel>
        </GroupBox>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
            <Border Background="#2E75B6" CornerRadius="5" Padding="15" Margin="0,0,10,0" MinWidth="130">
                <StackPanel>
                    <TextBlock Text="Общий доход" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TotalRevenue}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#5B9BD5" CornerRadius="5" Padding="15" Margin="0,0,10,0" MinWidth="130">
                <StackPanel>
                    <TextBlock Text="Количество сессий" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SessionCount}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FFC000" CornerRadius="5" Padding="15" Margin="0,0,10,0" MinWidth="130">
                <StackPanel>
                    <TextBlock Text="Средняя продолжительность" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AverageDuration}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#70AD47" CornerRadius="5" Padding="15" MinWidth="130">
                <StackPanel>
                    <TextBlock Text="Загруженность" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding OccupancyRate}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" Margin="0,0,0,16">
                <TabItem Header="Доходы по дням">
                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding DailyRevenue}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="День" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Доход" Binding="{Binding Value}" Width="Auto" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Распределение по компьютерам">
                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding ComputerDistribution}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Компьютер" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Сессии" Binding="{Binding Value}" Width="Auto" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Популярные тарифы">
                    <DataGrid AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding PopularTariffs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тариф" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Сессии" Binding="{Binding Value}" Width="Auto" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>

            <GroupBox Grid.Row="1" Header="Последние сессии">
                <DataGrid AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding RecentSessions}"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MinWidth="45"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="1.4*" MinWidth="120"/>
                        <DataGridTextColumn Header="Компьютер" Binding="{Binding ComputerName}" Width="Auto" MinWidth="95"/>
                        <DataGridTextColumn Header="Начало" Binding="{Binding FormattedStartTime}" Width="Auto" MinWidth="130"/>
                        <DataGridTextColumn Header="Окончание" Binding="{Binding FormattedEndTime}" Width="Auto" MinWidth="130"/>
                        <DataGridTextColumn Header="Продолжительность" Binding="{Binding CalculatedDuration}" Width="Auto" MinWidth="120"/>
                        <DataGridTextColumn Header="Стоимость" Binding="{Binding FormattedCost}" Width="Auto" MinWidth="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <Button Grid.Row="4"
                Content="Обновить статистику"
                Command="{Binding RefreshStatisticsCommand}"
                Width="150"
                Height="35"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
