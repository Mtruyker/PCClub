<UserControl x:Class="PCClubAdmin.Views.TariffsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PCClubAdmin.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="20">
        <!-- Заголовок экрана -->
        <TextBlock Text="Управление тарифами" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Панель управления -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить тариф" Command="{Binding ShowAddDialogCommand}" Width="120" Height="30" Margin="0,0,10,0"/>
            <Button Content="Обновить список" Command="{Binding RefreshTariffsCommand}" Width="120" Height="30"/>
        </StackPanel>

        <!-- Диалоговое окно добавления тарифа -->
        <Border Visibility="{Binding IsAddDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding DialogTitle}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Название тарифа:" FontWeight="SemiBold"/>
                    <controls:WatermarkTextBox
                           Height="25" Margin="0,5,0,0"
                           Watermark="Введите название тарифа"
                           Text="{Binding TariffName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Стоимость за час (руб.):" FontWeight="SemiBold"/>
                    <controls:WatermarkTextBox
                           Height="25" Margin="0,5,0,0"
                           Watermark="Введите стоимость"
                           Text="{Binding TariffCost, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Описание:" FontWeight="SemiBold"/>
                    <controls:WatermarkTextBox
                           Height="60" Margin="0,5,0,0"
                           Watermark="Введите описание тарифа"
                           TextWrapping="Wrap" AcceptsReturn="True"
                           Text="{Binding TariffDescription, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveTariffCommand}" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Отмена" Command="{Binding CancelAddTariffCommand}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица тарифов -->
        <DataGrid AutoGenerateColumns="False" Height="400" CanUserAddRows="False" ItemsSource="{Binding Tariffs}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Стоимость/час" Binding="{Binding CostPerHour, StringFormat={}{0:C}}" Width="120"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Редактировать"
                                        Command="{Binding DataContext.EditTariffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,5,0"/>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.DeleteTariffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>