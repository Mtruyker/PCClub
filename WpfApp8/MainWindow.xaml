<Window x:Class="PCClubAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПК Клуб — Администратор" Height="600" Width="900">
    <Window.Resources>
      
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#34495e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a647e"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2c3e50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Background="#2c3e50" VerticalAlignment="Top" Margin="0,10">
            <Button Content="Компьютеры" Click="NavigateToComputers" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Клиенты" Click="NavigateToClients" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Сессии" Click="NavigateToSessions" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Тарифы" Click="NavigateToTariffs" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Статистика" Click="NavigateToStatistics" Style="{StaticResource MenuButtonStyle}"/>
        </StackPanel>

        
        <Frame Grid.Column="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>