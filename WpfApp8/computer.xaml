<UserControl x:Class="PCClubAdmin.Views.ComputersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="20">
        <TextBlock Text="Управление компьютерами" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <Button Content="Добавить компьютер" Command="{Binding ShowAddDialogCommand}" Width="140" Height="30" Margin="0,0,0,10"/>

        <!-- Диалоговое окно добавления компьютера -->
        <Border Visibility="{Binding IsAddDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding DialogTitle}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Название:" FontWeight="SemiBold"/>
                    <TextBox Height="25" Margin="0,5,0,0" Text="{Binding ComputerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Статус:" FontWeight="SemiBold"/>
                    <ComboBox Height="25"
                              ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding SelectedStatus}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveComputerCommand}" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Отмена" Command="{Binding CancelAddComputerCommand}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid AutoGenerateColumns="False" Height="400" ItemsSource="{Binding Computers}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTemplateColumn Header="Статус" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                        Text="{Binding StatusText}"
                        Foreground="{Binding StatusColor}"
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Действия" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Редактировать"
                                        Command="{Binding DataContext.EditComputerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,5,0"/>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.DeleteComputerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>