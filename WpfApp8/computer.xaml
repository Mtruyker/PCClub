<UserControl x:Class="PCClubAdmin.Views.ComputersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infrastructure="clr-namespace:PCClubAdmin.Infrastructure">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <infrastructure:ComputerStatusBrushConverter x:Key="ComputerStatusBrushConverter"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление компьютерами" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <Button Grid.Row="1" Content="Добавить компьютер" Command="{Binding ShowAddDialogCommand}" Width="140" Height="30" Margin="0,0,0,10" HorizontalAlignment="Left"/>

        <!-- Диалоговое окно добавления компьютера -->
        <Border Grid.Row="2" Visibility="{Binding IsAddDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="20" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding DialogTitle}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Название:" FontWeight="SemiBold"/>
                    <TextBox Height="25" Margin="0,5,0,0" Text="{Binding ComputerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Статус:" FontWeight="SemiBold"/>
                    <ComboBox Height="25"
                              ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding SelectedStatus}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveComputerCommand}" Width="80" Margin="0,0,10,0"/>
                    <Button Content="Отмена" Command="{Binding CancelAddComputerCommand}" Width="80"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" AutoGenerateColumns="False" CanUserAddRows="False" ItemsSource="{Binding Computers}" HorizontalScrollBarVisibility="Disabled">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MinWidth="45"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                <DataGridTemplateColumn Header="Статус" Width="Auto" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                        Text="{Binding StatusText}"
                        Foreground="{Binding IsOccupied, Converter={StaticResource ComputerStatusBrushConverter}}"
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Действия" Width="Auto" MinWidth="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Редактировать"
                                        Command="{Binding DataContext.EditComputerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,5,0"/>
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.DeleteComputerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
